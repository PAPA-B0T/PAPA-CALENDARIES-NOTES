# Cloudflare Account ID is NOT your Telegram Chat ID.
# Find it in Cloudflare Dashboard. It looks like a long hex string.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Telegram bot token comes from @BotFather.
TELEGRAM_BOT_TOKEN=

# Worker name becomes part of the workers.dev URL.
WORKER_NAME=papa-calendaries-reminder
