{
    "manifest_version": 3,
    "name": "PAPA CALENDARIES NOTES",
    "version": "1.0.7",
    "description": "A lightweight, private browser extension for quick daily reflections and thoughts",
    "permissions": ["storage"],
    "background": {
      "service_worker": "service_worker.js"
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
      }
    },
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "commands": {
      "toggle-side-panel": {
        "suggested_key": {
          "default": "Alt+N",
          "mac": "Alt+N"
        },
        "description": "Toggle side panel"
      }
    },
    "icons": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
